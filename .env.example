# NeuroFlow Environment Variables
# Copy to .env and fill in all Required values before starting.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=           # Required: strong random password
POSTGRES_USER=neuroflow      # Required
POSTGRES_HOST=localhost      # Required
POSTGRES_PORT=5432           # Optional: default 5432
POSTGRES_DB=neuroflow        # Required

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=              # Required: strong random password
REDIS_HOST=localhost         # Required
REDIS_PORT=6379              # Optional: default 6379

# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=              # Required: sk-...
ANTHROPIC_API_KEY=           # Optional: sk-ant-... (needed for Anthropic provider)

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000  # Required: PostgreSQL or file URI

# ─── OpenTelemetry / Jaeger ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # Optional
OTEL_SERVICE_NAME=neuroflow-api                    # Optional

# ─── Security ────────────────────────────────────────────────────────────────
API_SECRET_KEY=              # Required: openssl rand -hex 32

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development      # Required: development | staging | production
LOG_LEVEL=INFO               # Optional: DEBUG | INFO | WARNING

# ─── Rate Limits ─────────────────────────────────────────────────────────────
INGEST_RATE_LIMIT_PER_HOUR=10    # Optional: default 10
QUERY_RATE_LIMIT_PER_MINUTE=60   # Optional: default 60

# ─── Queue Backpressure ──────────────────────────────────────────────────────
QUEUE_WARN_DEPTH=50          # Optional: default 50
QUEUE_BLOCK_DEPTH=100        # Optional: default 100
